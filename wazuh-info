#!/bin/bash
# wazuh-info - neofetch-style summary for the Wazuh server
# Prints system info alongside a Wazuh ASCII banner, plus
# Wazuh-specific facts: version, service health, agent count,
# alerts in the last 24h, and enrichment success count.

# -- Load indexer credentials from config file --

CONFIG_FILE="/var/ossec/etc/ollama-enrichment.conf"
INDEXER_USER=""
INDEXER_PASS=""

if [ -f "${CONFIG_FILE}" ]; then
    while IFS='=' read -r key value; do
        key=$(echo "$key" | xargs)
        value=$(echo "$value" | xargs)
        case "$key" in
            indexer_user) INDEXER_USER="$value" ;;
            indexer_pass) INDEXER_PASS="$value" ;;
        esac
    done < <(grep -v '^\s*#' "${CONFIG_FILE}" | grep -v '^\s*$')
fi

INDEXER_CREDS="${INDEXER_USER}:${INDEXER_PASS}"

# -- Colour constants --

COLOUR_BLUE='\033[1;34m'
COLOUR_CYAN='\033[1;36m'
COLOUR_GREEN='\033[1;32m'
COLOUR_YELLOW='\033[1;33m'
COLOUR_RESET='\033[0m'

# -- System facts --

hostname_str=$(hostname)
current_user=$(whoami)
os_name=$(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"')
kernel_version=$(uname -r)
uptime_str=$(uptime -p | sed 's/^up //')
cpu_model=$(grep 'model name' /proc/cpuinfo | head -1 | cut -d: -f2 | xargs)
cpu_cores=$(nproc)
memory_usage=$(free -h | awk '/^Mem:/ {print $3 " / " $2}')
disk_usage=$(df -h / | awk 'NR==2 {print $3 " / " $2 " (" $5 ")"}')
ip_address=$(hostname -I | awk '{print $1}')

# -- Wazuh facts --

wazuh_version=$(/var/ossec/bin/wazuh-control info 2>/dev/null \
    | awk -F\" '/WAZUH_VERSION/ {print $2}')
manager_status=$(systemctl is-active wazuh-manager 2>/dev/null)
indexer_status=$(systemctl is-active wazuh-indexer 2>/dev/null)
dashboard_status=$(systemctl is-active wazuh-dashboard 2>/dev/null)
active_agent_count=$(/var/ossec/bin/agent_control -ls 2>/dev/null \
    | grep -c ",Active")

# Query OpenSearch for alert counts in the last 24 hours
alerts_last_24h=$(curl -sk -u "${INDEXER_CREDS}" \
    -H 'Content-Type: application/json' \
    "https://127.0.0.1:9200/wazuh-alerts-*/_count" \
    -d '{"query":{"range":{"timestamp":{"gte":"now-24h"}}}}' \
    2>/dev/null | grep -oP '"count":\K[0-9]+')

level_10_plus_last_24h=$(curl -sk -u "${INDEXER_CREDS}" \
    -H 'Content-Type: application/json' \
    "https://127.0.0.1:9200/wazuh-alerts-*/_count" \
    -d '{
        "query":{"bool":{"filter":[
            {"range":{"timestamp":{"gte":"now-24h"}}},
            {"range":{"rule.level":{"gte":10}}}
        ]}}
    }' 2>/dev/null | grep -oP '"count":\K[0-9]+')

enrichment_success_count=$(grep -c '"status": "success"' \
    /var/ossec/logs/ollama-enrichment.log 2>/dev/null)

# -- Print banner with system and Wazuh info --

printf "${COLOUR_BLUE}      __        __              _       ${COLOUR_RESET}    ${COLOUR_CYAN}%s${COLOUR_RESET}@${COLOUR_CYAN}%s${COLOUR_RESET}\n" "$current_user" "$hostname_str"
printf "${COLOUR_BLUE}      \\ \\      / /_ _ _____   _| |__    ${COLOUR_RESET}    ----------------------------\n"
printf "${COLOUR_BLUE}       \\ \\ /\\ / / _\` |_  / | | | '_ \\   ${COLOUR_RESET}    ${COLOUR_YELLOW}OS:${COLOUR_RESET}         %s\n" "$os_name"
printf "${COLOUR_BLUE}        \\ V  V / (_| |/ /| |_| | | | |  ${COLOUR_RESET}    ${COLOUR_YELLOW}Kernel:${COLOUR_RESET}     %s\n" "$kernel_version"
printf "${COLOUR_BLUE}         \\_/\\_/ \\__,_/___|\\__,_|_| |_|  ${COLOUR_RESET}    ${COLOUR_YELLOW}Uptime:${COLOUR_RESET}     %s\n" "$uptime_str"
printf "                                            ${COLOUR_YELLOW}IP:${COLOUR_RESET}         %s\n" "$ip_address"
printf "                                            ${COLOUR_YELLOW}CPU:${COLOUR_RESET}        %s (%s cores)\n" "$cpu_model" "$cpu_cores"
printf "                                            ${COLOUR_YELLOW}Memory:${COLOUR_RESET}     %s\n" "$memory_usage"
printf "                                            ${COLOUR_YELLOW}Disk /:${COLOUR_RESET}     %s\n" "$disk_usage"
printf "                                            ----------------------------\n"
printf "                                            ${COLOUR_GREEN}Wazuh:${COLOUR_RESET}      %s\n" "${wazuh_version:-unknown}"
printf "                                            ${COLOUR_GREEN}Manager:${COLOUR_RESET}    %s\n" "$manager_status"
printf "                                            ${COLOUR_GREEN}Indexer:${COLOUR_RESET}    %s\n" "$indexer_status"
printf "                                            ${COLOUR_GREEN}Dashboard:${COLOUR_RESET}  %s\n" "$dashboard_status"
printf "                                            ${COLOUR_GREEN}Agents:${COLOUR_RESET}     %s active\n" "$active_agent_count"
printf "                                            ${COLOUR_GREEN}Alerts 24h:${COLOUR_RESET} %s (%s at level 10+)\n" "${alerts_last_24h:-0}" "${level_10_plus_last_24h:-0}"
printf "                                            ${COLOUR_GREEN}Enriched:${COLOUR_RESET}   %s (since deploy)\n" "${enrichment_success_count:-0}"
printf "\n"
